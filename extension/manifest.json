{
  "manifest_version": 3,
  "name": "1taff4me",
  "version": "1.0.0",
  "description": "Ajoute une offre d'emploi à ton tableau 1taff4me en un clic",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ajouter à 1taff4me",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.welcometothejungle.com/*",
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/*",
        "*://*.indeed.fr/*",
        "*://*.hellowork.com/*",
        "*://*.monster.fr/*",
        "*://*.apec.fr/*",
        "*://*.francetravail.fr/*",
        "*://*.pole-emploi.fr/*",
        "*://*.cadremploi.fr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
