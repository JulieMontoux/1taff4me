# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/taff4me

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# OAuth - GitHub (https://github.com/settings/developers)
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@1taff4me.com

# France Travail API (https://francetravail.io/data/api)
FRANCE_TRAVAIL_CLIENT_ID=your-client-id
FRANCE_TRAVAIL_CLIENT_SECRET=your-client-secret

# Pappers API (https://www.pappers.fr/api)
PAPPERS_API_KEY=your-pappers-api-key
